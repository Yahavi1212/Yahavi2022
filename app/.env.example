# Copy this file to app/.env (never commit .env to git)
#
# Backend base URL.
#   Default (unset): https://shop.hackknow.com
#   Hide subdomain via nginx reverse proxy: set to empty string.
# VITE_WP_API_BASE=
#
# Razorpay key. The server normally returns the live key in /order, so this
# only matters for local dev or as a fallback.
VITE_RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY

# Copy this file to .env and fill in your real values
# NEVER commit .env to git
#
# In production, leave VITE_WORDPRESS_URL unset (or use a relative path) so
# requests are routed through the hackknow.com nginx reverse proxy and the
# shop.hackknow.com origin stays hidden from end users.
# For local development you can point it directly at the WordPress site.

# VITE_WORDPRESS_URL=https://shop.hackknow.com/graphql
# VITE_WORDPRESS_API_BASE=https://shop.hackknow.com/wp-json/hackknow/v1

VITE_RAZORPAY_KEY_ID=rzp_live_REPLACE_WITH_YOUR_KEY
